<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AppToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/toolbar_height"
        app:title="@string/story_title"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero image -->
            <ImageView
                android:id="@+id/iv_inscription_image"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="centerCrop"
                android:background="@color/surface_warm"/>

            <!-- Parchment-style story card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@color/surface_warm">

                <TextView
                    android:id="@+id/tv_inscription_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:text="Inscription Name"/>

                <TextView
                    android:id="@+id/tv_location_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:text="📍 Location"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginVertical="16dp"/>

                <!-- Metadata chips -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DYNASTY"
                            style="@style/TextAppearance.Section.Title"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tv_dynasty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp"
                            android:text="—"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PERIOD"
                            style="@style/TextAppearance.Section.Title"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tv_period"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp"
                            android:text="—"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Translation section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODERN KANNADA TRANSLATION"
                    style="@style/TextAppearance.Section.Title"/>

                <!-- Loading indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_translate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    app:indicatorColor="@color/primary"
                    android:indeterminate="true"
                    android:visibility="gone"/>

                <!-- Translation parchment card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_translation"
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Decorative quote mark -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="""
                            android:textSize="36sp"
                            android:textColor="@color/accent"
                            android:lineSpacingMultiplier="0.5"/>

                        <TextView
                            android:id="@+id/tv_translation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.7"
                            android:layout_marginTop="4dp"
                            android:text="Translation will appear here after AI analysis."/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Gift/Law section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIFT / LAW RECORDED"
                    style="@style/TextAppearance.Section.Title"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:id="@+id/tv_gift_law"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="8dp"
                    android:text="—"/>

                <!-- Translate button (for user-uploaded) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_translate"
                    style="@style/AppButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="🔍 Decode with AI"
                    android:layout_marginTop="24dp"
                    android:visibility="gone"/>

                <View android:layout_width="match_parent" android:layout_height="32dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
