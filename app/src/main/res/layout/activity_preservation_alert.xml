<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AppToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/toolbar_height"
        app:title="@string/alert_title"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info banner -->
            <androidx.cardview.widget.CardView
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_warm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="28sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Found a damaged or at-risk inscription? Report it so we can act fast to protect our heritage."
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginStart="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Photo of damage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTO OF DAMAGE"
                style="@style/TextAppearance.Section.Title"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="180dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/iv_damage_photo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@color/surface_warm"/>

                    <LinearLayout
                        android:id="@+id/layout_photo_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/surface_warm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="40sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap to add photo"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_damage_camera"
                    style="@style/AppButton.Outline"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="📷 Camera"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_damage_gallery"
                    style="@style/AppButton.Outline"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🖼️ Gallery"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

            <!-- Damage type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TYPE OF DAMAGE"
                style="@style/TextAppearance.Section.Title"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rg_damage_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_painted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎨 Painted Over"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"
                    android:padding="8dp"/>

                <RadioButton
                    android:id="@+id/rb_broken"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💔 Broken / Cracked"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"
                    android:padding="8dp"/>

                <RadioButton
                    android:id="@+id/rb_buried"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⬇️ Buried / Hidden"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"
                    android:padding="8dp"/>

                <RadioButton
                    android:id="@+id/rb_other"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❓ Other"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"
                    android:padding="8dp"/>

            </RadioGroup>

            <!-- Location -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_location"
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍"
                        android:textSize="20sp"/>

                    <TextView
                        android:id="@+id/tv_location_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tap to capture location"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_get_location"
                        style="@style/AppButton.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Get"
                        android:paddingHorizontal="12dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Notes -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Additional notes (optional)"
                app:boxStrokeColor="@color/primary_light"
                app:hintTextColor="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:inputType="textMultiLine|textCapSentences"
                    android:gravity="top"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Submit -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit_alert"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/submit_alert"
                android:layout_marginTop="24dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_upload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:indicatorColor="@color/primary"
                android:indeterminate="true"/>

            <View android:layout_width="match_parent" android:layout_height="40dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
